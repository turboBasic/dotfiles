            as='completion' \
            is-snippet \
        https://raw.githubusercontent.com/docker/cli/master/contrib/completion/zsh/_docker \
            \
            id-as='_gpg' \
            as='completion' \
            is-snippet \
        https://raw.githubusercontent.com/johan/zsh/master/Completion/Unix/Command/_gpg \
            \
            id-as='_kubectl' \
            as='completion' \
            nocompile='!' \
            pick='_kubectl' \
