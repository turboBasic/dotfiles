##  Async functions

function safe-echo {
    printf "\n%s\n" "$1"
    zle && zle reset-prompt
}

function set-env-var-async() {
    local worker="bw_worker"

    set_env_async_var_name="$1"
    local func_name="$2"

    # If function does not exist, reset to dummy variable and function
    if ! typeset -f "$func_name" &>/dev/null; then
        func_name="true"
        set_env_async_var_name="set_env_async_dummy"
    fi

    # Save remaining arguments for chained calls
    shift 2
    declare -ag args=( "$@" )

    # Define a function to process the result of the job
    # See https://github.com/mafredri/zsh-async?tab=readme-ov-file#functions
    # $1: Job name
    # $2: Exit code of the job
    # $3: Stdout of the job
    #
    # shellcheck disable=2296,2317
    function set-env-async-callback() {
        # dummy values for non-existent functions are ignored
        if [[ "$2" -eq 0 && "$set_env_async_var_name" != "set_env_async_dummy" ]]; then
            typeset -gx "${set_env_async_var_name}"="$3"
            safe-echo "✅ $set_env_async_var_name set to ${(P)set_env_async_var_name}"
        else
            unset "${set_env_async_var_name}"
        fi
        unset set_env_async_var_name
        async_stop_worker "$worker"

        if [[ ${#args} -gt 0 ]]; then
            # execute the next functions in the chain

            #shellcheck disable=SC2068
            set-env-var-async "${args[@]}"
        else
            unset args
        fi
    }

    async_start_worker "$worker" -n
    async_register_callback "$worker" set-env-async-callback
    async_job "$worker" "$func_name"
}


