FROM ubuntu:24.04 AS builder

RUN apt-get update && apt-get install -y \
    curl build-essential pkg-config libdbus-1-dev libssl-dev git \
    && rm -rf /var/lib/apt/lists/*

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

ARG RBW_VERSION=1.15.0
RUN cargo install rbw --version "${RBW_VERSION}"

FROM scratch
COPY --from=builder /root/.cargo/bin/rbw /rbw
COPY --from=builder /root/.cargo/bin/rbw-agent /rbw-agent
