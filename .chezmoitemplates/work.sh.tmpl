# shellcheck disable=2155
function aws-set-profile() {
    local profile_alias=$1
    local bw_aws_item_name=$(bw-get-field work.2025.05@main bw_aws_item_name)

    case $profile_alias in
        int)
            local account_id=$(bw-get-field "$bw_aws_item_name" mb_int_account_id)
            export AWS_PROFILE="Idp${account_id}DhcFullAdmin"
            ;;
        prod)
            local account_id=$(bw-get-field "$bw_aws_item_name" mb_prod_account_id)
            export AWS_PROFILE="Idp${account_id}DhcFullAdmin"
            ;;
        *)
            echo "Invalid profile alias: $profile_alias. Should be 'int' or 'prod'"
            export AWS_PROFILE=
            return 1
            ;;
    esac
}

# shellcheck disable=2155
function tfe() {
    local bw_tfe_uici_item_name=$(bw-get-field work.2025.05@main bw_tfe_uici_item_name)
    local tfe_uici_uri=$(bw get uri "$bw_tfe_uici_item_name")

    # TFE_TOKEN is assigned asynchronously
    curl --silent \
        --header "Authorization: Bearer $TFE_TOKEN" \
        --header "Content-Type: application/vnd.api+json" \
        "$tfe_uici_uri/api/v2/$1"
}

# shellcheck disable=2155
function tfe-get-token() {
    local bw_tfe_uici_item_name=$(bw-get-field work.2025.05@main bw_tfe_uici_item_name)
    bw-get-field "$bw_tfe_uici_item_name" 24-12-09-default-token
}

