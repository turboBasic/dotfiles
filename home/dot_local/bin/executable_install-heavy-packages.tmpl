#!/bin/sh

# chezmoi:template:left-delimiter=#{ right-delimiter=}#

# Install heavy Homebrew packages on demand.

if ! command -v brew >/dev/null 2>&1; then
    echo "Error: Homebrew is not installed." >&2
    exit 1
fi

#{ if eq .chezmoi.os "darwin" -}#
brew bundle --file=/dev/stdin <<EOF

#{- range .packages.darwin.manual.formulae -}#
  #{- if eq "map" (kindOf .) }#
    tap #{ .tap | quote }#
    brew #{ .name | quote }#
  #{- else }#
    brew #{ . | quote }#
  #{- end }#
#{- end }#

#{- range .packages.darwin.manual.casks -}#
  #{- if eq "map" (kindOf .) }#
    tap #{ .tap | quote }#
    cask #{ .name | quote }#
  #{- else }#
    cask #{ . | quote }#
  #{- end }#
#{- end }#

EOF
#{- end }#

#{ if eq .chezmoi.os "linux" -}#
brew bundle --file=/dev/stdin <<EOF

#{- range .packages.linux.manual.formulae -}#
  #{- if eq "map" (kindOf .) }#
    tap #{ .tap | quote }#
    brew #{ .name | quote }#
  #{- else }#
    brew #{ . | quote }#
  #{- end }#
#{- end }#

EOF
#{- end }#
