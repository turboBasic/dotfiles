    "Post": {
        "prefix": "post",
        "body": [
            "post {",
            "    always {",
            "        ${1}echo 'post action'",
            "    }",
            "    aborted {",
            "        ${2}echo 'aborted post action'",
            "    }",
            "    failure {",
            "        ${3}echo 'failure post action'",
            "    }",
            "    success {",
            "        ${4}echo 'success post action'",
            "    }",
            "}"
        ],
        "description": "Scope: pipeline, stage",
    },


    "RecipeParallel": {
        "prefix": "recipeParallel",
        "body": [
            "List getNodes() {",
            "    String allNodes = (params.LIST_OF_NODES ?: '') ",
            "    (allNodes.trim() ?: 'vm2-linux,vm4-linux,vm8-linux') ",
            "    .split(',') ",
            "    .collect { it.trim() } ",
            "} ",
            "",
            "",
            "Closure newStep(String theNode) { ",
            "    { -> stage(theNode) { ",
            "            node(theNode) { ",
            "                sh ''' ",
            "                    hostname   # and other commands ",
            "                ''' ",
            "            }",
            "        }",
            "    }",
            "} ",
            "",
            "",
            "Map nodeScripts = getNodes().collectEntries { ",
            "    [ (it): newStep(it) ] ",
            "} ",
            "nodeScripts << [ failFast: false ] ",
            "",
            "",
            "pipeline { ",
            "    agent none",
            "    parameters { ",
            "        string( ",
            "            name: 'LIST_OF_NODES', ",
            "            defaultValue: 'vm2-linux,vm4-linux,vm8-linux', ",
            "            description: 'Comma-separated list of nodes.' ",
            "        )",
            "    }",
            "",
            "    stages {",
            "        stage('Initialization') {",
            "            steps {",
            "                script {",
            "                    parallel nodeScripts ",
            "                }",
            "            }",
            "        }",
            "    }",
            "}",
        ],
        "description": "Recipe for running similar stages in parallel",
    },


    "Triggers": {
        "prefix": "triggers",
        "body": [
            "triggers {",
            "    cron('H */4 * * 1-5') ",
            "    gerrit( ",
            "        serverName: 'EDC-Gerrit', ",
            "        gerritProjects: [[ ",
            "            compareType: 'PLAIN', ",
            "            pattern: 'widget-library-ex', ",
            "            branches: [[",
            "                compareType: 'PLAIN', ",
            "                pattern: 'junk/submodule-integration', ",
            "            ]], ",
            "            filePaths: [ ",
            "                [ ",
            "                    pattern: 'uisdk/framework/**', ",
            "                    compareType: 'ANT', ",
            "                ], ",
            "                [ ",
            "                    pattern: 'uisdk/widget-library/**', ",
            "                    compareType: 'ANT', ",
            "                ], ",
            "            ], ",
            "        ]], ",
            "        triggerOnEvents: [ ",
            "            changeMerged(), ",
            "            patchsetCreated( excludeDrafts: true ), ",
            "            commentAddedContains('Test-Verified\\+1'), ",
            "        ] ",
            "        commentTextParameterMode: 'PLAIN',",
            "        commitMessageParameterMode: 'PLAIN',",
            "        silentMode: true",
            "    ) ",
            "} ",
        ],
        "description": "Scope: pipeline",
    },


    "When": {
        "prefix": "when",
        "body": [
            "when {",
            "    expression { ${1:!params.INVOKE_PARAMETERS} }",
            "}"
        ],
        "description": "Scope: stage",
    },


    "WithCredentials": {
        "prefix": "withCred",
        "body": [
            "withCredentials([ ",
            "    sshUserPrivateKey( ",
            "        credentialsId: 'id-ssh', ",
            "        keyFileVariable: 'CRED_SSHUSERPRIVATEKEY_KEYFILE', ",
            "        usernameVariable: 'CRED_SSHUSERPRIVATEKEY_USERNAME', ",
            "        passphraseVariable: 'CRED_SSHUSERPRIVATEKEY_PASSPHRASE' ",
            "    ), ",
            "    usernameColonPassword( credentialsId: 'id-user-password', variable: 'CRED_USERNAMECOLONPASSWORD' ), ",
            "    string( credentialsId: 'id-string', variable: 'CRED_STRING' ), ",
            "    file( credentialsId: 'id-file', variable: 'CRED_FILE'), ",
            "]) { ",
            "    sh ''' ",
            "        echo \\${CRED_SSHUSERPRIVATEKEY_KEYFILE} \\${CRED_SSHUSERPRIVATEKEY_USERNAME} \\${CRED_SSHUSERPRIVATEKEY_PASSPHRASE} ",
            "        echo \\${CRED_USERNAMECOLONPASSWORD} ",
            "        echo \\${CRED_STRING} ",
            "        echo \\${CRED_FILE} ",
            "    ''' ",
            "}",
        ],
        "description": "Scope: steps, script",
    },


    "Abort Job if parameters changed": {
        "prefix": "abortJobIfParametersChanged",
        "body": [
            "stage('1') {",
            "    steps {",
            "        sh 'env | sort'",
            "        abortIfParametersChanged()",
            "    }",
            "}",
            "",
            "void abortIfParametersChanged() {",
            "    if (params.INVOKE_PARAMETERS) {",
            "        echo 'Parameters in web configuration are updated from the Job source code'",
            "        timeout(time: 100, unit: 'MILLISECONDS') {",
            "            sleep 1",
            "        }",
            "    }",
            "}"
        ],
        "description": "Abort Job if parameters changed"
    }

}
