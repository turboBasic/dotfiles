    "Parameters": {
        "prefix": "param",
        "body": [
            "parameters {",
            "    string(name: '${1:TAG}', defaultValue: 'v2.100.1', description: 'Tag for build')",
            "    booleanParam(name: '${2:SKIP_COMPILE}', defaultValue: false, description: 'Skip Compile stage')",
            "    choice(name: '${3:CHOICE_PARAM}', choices: \"No\\nYes\", description: 'Choices separated by new lines, the first one is default value')",
            "    booleanParam(name: '${4:DRY_RUN}', defaultValue: true, description: 'Output information instead of executing commands')",
            "        booleanParam(",
            "            name: '${5:INVOKE_PARAMETERS}',",
            "            defaultValue: false, ",
            "            description: 'Populate job parameters in web view from job\\'s source' ",
