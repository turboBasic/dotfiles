    "Pipeline": {
        "prefix": "pipe",
        "body": [
            "pipeline {",
            "    agent any",
            "    options {",
            "        ansiColor('xterm')",
            "    }",
            "    parameters {",
            "        booleanParam(",
            "            name: 'INVOKE_PARAMETERS',",
            "            defaultValue: false, ",
            "            description: \"Populate job parameters in web view from job's source\"",
            "        )",
            "    }",
            "    stages {",
            "        stage('Reconfigure Job parameters') {",
            "            when {",
            "                expression { shouldReconfigureParameters() }",
            "            }",
            "            steps {",
            "                script {",
            "                    currentBuild.displayName = \"reconfigure parameters\"",
            "                    abortIf(true, 'Parameters in web configuration are updated')",
            "                }",
            "            }",
            "        }",
            "        stage('Initialization') {",
            "            steps {",
            "                echo \"\\u001B[31mColor in echo commands\\u001B[0m\\n\"",
            "                sh '''set +x",
            "                    printf \"\\u001B[31mColor in shell script\\u001B[0m\\n\"",
            "                '''",
            "                printEnvironment()",
            "            }",
            "        }",
            "    }",
            "    post {",
            "        always {",
            "            echo \"currentBuild.result = \\${currentBuild.result}\"",
            "        }",
            "        failure {",
            "            echo ' '",
            "        }",
            "        success {",
            "            echo ' '",
            "        }",
            "    }",
            "}",
            "",
            "",
            "void abortIf(boolean condition, String conditionDescription = 'UNSPECIFIED CONDITION') {",
            "    if (condition) {",
            "        echo \"INFO: [abortIf()]: Abort job by condition = ‘\\${conditionDescription}’\"",
            "        timeout(time: 100, unit: 'MILLISECONDS') {",
            "            sleep 1",
            "        }",
            "    }",
            "}",
            "",
            "void printEnvironment() {",
            "    sh '''",
            "        printenv |",
            "        sort |",
            "        awk -F= '{ printf \"%-40s %s \\\\\\\\n\", \\\\\\$1, \\\\\\$2 }'",
            "    '''",
            "}",
            "",
            "boolean shouldReconfigureParameters() {",
            "    !currentBuild.getPreviousBuild() ||",
            "    params?.INVOKE_PARAMETERS",
            "}"
        ],
        "description": "Creates declarative pipeline job file"
    },


    "Agent": {
        "prefix": "agent",
        "body": [
            "agent {",
            "    label $1'linux && test1 || test2'",
            "}",
            "// agent any"
        ],
        "description": "Scope: pipeline, stage"
    },


