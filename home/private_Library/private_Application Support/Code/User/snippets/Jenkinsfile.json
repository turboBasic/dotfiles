    "Options": {
        "prefix": "opt",
        "body": [
            "options {",
            "    buildDiscarder( ",
            "        logRotator( ",
            "            daysToKeepStr: '3', ",
            "            numToKeepStr: '30'  ",
            "        ) ",
            "    ) ",
            "    disableConcurrentBuilds()",
            "    timestamps()",
            "    timeout(time: 15, unit: 'MINUTES')",
            "}"
        ],
        "description": "Scope: pipeline",
