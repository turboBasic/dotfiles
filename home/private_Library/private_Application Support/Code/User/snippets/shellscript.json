    "Simple shell template": {
        "prefix": "simple",
        "body": [
            "#!/usr/bin/env bash",
            "",
            "[ -n \"BASH_VERSION\" ] || {",
            "    printf >&2  \"[] %s\\n\" \"This script should only be executed by bash shell.\"",
            "    exit 66",
            "}",
            "if [ \"$(isSourced)\" = 1 ]; then",
            "    printf >&2  \"[] [INFO] %s\\n\" \"Script has been sourced. Functions are available\"",
            "    sleep 3s",
            "else",
            "    set -o errexit \\",
            "        -o nounset \\",
            "        -o pipefail",
            "    shopt -s extdebug",
            "fi",
            "",
            "onExit() {",
            "    local state=$?",
            "",
            "    if [ -z \"$_SKIP_ERROR\" ]; then",
            "        if [ $state -ne 0 ]; then",
            "            printf >&2  \"[$0] %s\\n\" \"Exiting on error in line ‘$LINENO’: ‘$BASH_COMMAND’\"",
            "            exit $state",
            "        fi",
            "        printf >&2 \"[${FUNCNAME[0]}] %s\\n\" 'Exiting script...'",
            "    fi",
            "}",
            "trap onExit EXIT",
            "",
            "",
            "",
            "",
            "main() {",
            "    local -",
            "    local -a options=(  )",
            "",
            "    while [ $# -gt 0 ]; do",
            "        case \"$1\" in",
            "            -r | --rawfile )",
            "                [ -z \"${options[@]}\" ] || exit 2",
            "                options+=( --rawfile \"$2\" )",
            "                shift",
            "                shift",
            "                ;;",
            "            -d | --default )",
            "                [ -z \"${options[@]}\" ] || exit 2",
            "                options+=( --default \"$2\" )",
            "                shift",
            "                shift",
            "                ;;",
            "            -- )",
            "                shift",
            "                break",
            "                ;;",
            "            -* )",
            "                exit 3",
            "                ;;",
            "            * )",
            "                break",
            "        esac",
            "    done",
            "",
            "    if [ $# -gt 0 ]; then",
            "        local fileName=$1",
            "        shift",
            "        if [ -z \"${options[@]}\" ]; then",
            "            options+=( --rawfile \"$fileName\" )",
            "            [ -n \"$fileName\" ] || exit 2",
            "        fi",
            "    fi",
            "",
            "    printf '<%s> \\n' \"${options[@]}\"",
            "}",
            "",
            "main \"$@\""
        ],
        "description": "Creates instance of VS Code snippet",
    }
}
