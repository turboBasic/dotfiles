# shellcheck disable=SC2034,SC2148

# Disable Apple's "save/restore shell state" feature (https://superuser.com/a/1610999/317385)
SHELL_SESSIONS_DISABLE=1

# Disable global completion initialization (Ubuntu)
skip_global_compinit=1

typeset -U FPATH fpath
typeset -U PATH path
typeset -U MANPATH manpath
typeset -U CDPATH cdpath

cdpath=( "$HOME/00-projects" )

export LANG=en_GB.UTF-8

export EDITOR='nvim'
export FZF_DEFAULT_COMMAND='rg --files --no-ignore --hidden --follow --glob "!.git/*"'
export FZF_DEFAULT_OPTS='--height 50% --ansi --info=inline'
export LESS="\
--buffers=128 \
--HILITE-UNREAD \
--ignore-case \
--LONG-PROMPT \
--max-back-scroll=15 \
--no-init \
--quiet \
--quit-at-eof \
--quit-if-one-screen \
--RAW-CONTROL-CHARS \
--status-line \
--tabs=4 \
--window=-4\
"
export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/ripgreprc"

# colored Man pages
export MANPAGER="less --use-color --color=d+g --color=u+y"
export MANROFFOPT="-c"


